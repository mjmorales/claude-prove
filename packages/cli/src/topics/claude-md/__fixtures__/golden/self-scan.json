    },
    {
      "name": "orchestrator",
      "summary": "Unified entry point for orchestrator, autopilot, and full-auto execution"
    },
    {
      "name": "plan",
      "summary": "Plan a task or a specific step from the active plan.json"
    },
    {
      "name": "review-ui",
      "summary": "Loopback review UI for inspecting prove runs, ACB intent groups, and verdicts"
    },
    {
      "name": "scrum",
      "summary": "Operate the scrum store backed by `.prove/prove.db` (tasks, milestones, tags, run-links)"
    },
    {
      "name": "workflow",
      "summary": "Run a milestone/task tree as parallel waves via orchestrator full-mode, mirroring status to scrum"
