  "validate/non_run_state_path": {
    "hook": "validate",
    "setup": {
      "write_file": "PROJECT/other.json",
      "content_json": { "foo": "bar" }
    },
    "payload": {
      "tool_name": "Write",
      "tool_input": { "file_path": "PROJECT/other.json" }
    }
  },
  "validate/non_mutating_tool": {
    "hook": "validate",
    "payload": {
      "tool_name": "Bash",
      "tool_input": { "command": "ls" }
    }
  },
  "session_start/resume_active_run": {
    "hook": "session-start",
    "setup": {
      "write_file": "PROJECT/.prove/runs/feature/demo/state.json",
      "content_json": {
        "schema_version": "1",
        "kind": "state",
        "run_status": "running",
        "slug": "demo",
        "branch": "feature",
        "updated_at": "t",
        "current_step": "1.1.1",
        "tasks": []
      }
    },
    "payload": { "cwd": "PROJECT" }
  },
  "session_start/compact_active_run": {
    "hook": "session-start",
    "setup": {
      "write_file": "PROJECT/.prove/runs/feature/demo/state.json",
      "content_json": {
        "schema_version": "1",
        "kind": "state",
        "run_status": "halted",
        "slug": "demo",
        "branch": "feature",
        "updated_at": "t",
        "current_step": "",
        "tasks": []
      }
    },
    "payload": { "cwd": "PROJECT" }
  },
  "session_start/no_active_run": {
    "hook": "session-start",
    "payload": { "cwd": "PROJECT" }
  },
  "session_start/skips_completed_runs": {
    "hook": "session-start",
    "setup": {
      "write_file": "PROJECT/.prove/runs/main/done/state.json",
      "content_json": {
        "schema_version": "1",
        "kind": "state",
        "run_status": "completed",
        "slug": "done",
        "branch": "main",
        "updated_at": "t",
        "tasks": []
      }
    },
    "payload": { "cwd": "PROJECT" }
  },
  "stop/no_active_runs": {
    "hook": "stop",
    "payload": { "cwd": "PROJECT" }
  },
  "subagent_stop/no_slug_marker": {
    "hook": "subagent-stop",
    "payload": { "cwd": "PROJECT" }
  },
  "subagent_stop/no_payload": {
    "hook": "subagent-stop",
    "raw_stdin": ""
  },
  "stop/no_inprogress": {
    "hook": "stop",
    "setup": {
      "write_file": "PROJECT/.prove/runs/feature/demo/state.json",
      "content_json": {
        "schema_version": "1",
        "kind": "state",
        "run_status": "pending",
        "slug": "demo",
        "branch": "feature",
        "updated_at": "t",
        "tasks": [
          {
            "id": "1.1",
            "status": "pending",
            "started_at": "",
            "ended_at": "",
            "review": { "verdict": "pending", "notes": "", "reviewer": "", "reviewed_at": "" },
            "steps": [
              {
                "id": "1.1.1",
                "status": "pending",
                "started_at": "",
                "ended_at": "",
                "commit_sha": "",
                "validator_summary": {
                  "build": "pending",
                  "lint": "pending",
                  "test": "pending",
                  "custom": "pending",
                  "llm": "pending"
                },
                "halt_reason": ""
              }
            ]
          }
        ],
        "dispatch": { "dispatched": [] }
      }
    },
    "payload": { "cwd": "PROJECT" }
  }
