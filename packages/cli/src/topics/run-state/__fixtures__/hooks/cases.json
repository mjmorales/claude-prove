{
  "guard/block_state": {
    "hook": "guard",
    "payload": {
      "tool_name": "Write",
      "tool_input": {
        "file_path": "PROJECT/.prove/runs/main/demo/state.json"
      }
    }
  },
  "guard/block_state_backslash": {
    "hook": "guard",
    "payload": {
      "tool_name": "Edit",
      "tool_input": {
        "file_path": "PROJECT\\.prove\\runs\\main\\demo\\state.json"
      }
    }
  },
  "guard/allow_non_state": {
    "hook": "guard",
    "payload": {
      "tool_name": "Write",
      "tool_input": {
        "file_path": "PROJECT/.prove/runs/main/demo/plan.json"
      }
    }
  },
  "guard/multi_edit_state": {
    "hook": "guard",
    "payload": {
