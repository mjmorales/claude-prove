          }
        ]
      }
    },
    "payload": {
      "tool_name": "Write",
      "tool_input": { "file_path": "PROJECT/.prove/runs/main/demo/plan.json" }
    }
  },
  "validate/invalid_plan": {
    "hook": "validate",
