{
  "name": "acb-vscode",
  "displayName": "ACB Review",
  "description": "Review AI-generated code changes organized by intent using Agent Change Brief documents",
  "version": "0.1.0",
  "publisher": "acb",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "acb.reviewEditor",
        "displayName": "ACB Review",
        "selector": [
          {
            "filenamePattern": "*.acb.json"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "acb.openReview",
        "title": "ACB: Open Review"
      }
    ]
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "build:webview": "esbuild webview/src/index.tsx --bundle --outfile=dist/webview/index.js --format=esm --loader:.tsx=tsx --loader:.ts=ts",
    "watch": "npm run build -- --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0"
  },
  "dependencies": {
    "@acb/core": "*"
  }
}
