#!/usr/bin/env bash
#
# ACB pre-commit hook: rejects commits that lack an intent manifest.
#
# When an agent (or human) stages changes and runs `git commit`, this hook
# checks for a pending intent manifest at .acb/intents/staged.json. If missing,
# the commit is rejected with instructions to write one first.
#
# This is the forcing function that ensures every commit carries first-party
# intent declarations for ACB assembly.
#
# To bypass (manual/human commits): git commit --no-verify
# To install: git config core.hooksPath packages/acb-core/hooks

set -euo pipefail

MANIFEST_DIR=".acb/intents"
STAGED_MANIFEST="$MANIFEST_DIR/staged.json"

# Skip if ACB manifests are explicitly disabled
if [ "${ACB_SKIP_MANIFEST:-}" = "1" ]; then
  exit 0
fi

# Skip for merge commits (they have MERGE_HEAD)
if [ -f ".git/MERGE_HEAD" ]; then
  exit 0
fi

# Skip for amend commits that are just adding the manifest itself
if [ "${ACB_AMENDING:-}" = "1" ]; then
  exit 0
fi

# Check if there are any staged changes (empty commits should pass)
STAGED_FILES=$(git diff --cached --name-only 2>/dev/null || true)
if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# Skip if the only staged file IS the manifest
if [ "$STAGED_FILES" = "$STAGED_MANIFEST" ]; then
  exit 0
fi

# Check for the staged manifest
if [ ! -f "$STAGED_MANIFEST" ]; then
  cat >&2 <<'EOF'

╔══════════════════════════════════════════════════════════════╗
║  ACB Intent Manifest Required                                ║
╚══════════════════════════════════════════════════════════════╝

Before committing, write an intent manifest to declare what
these changes do and why.

Write to: .acb/intents/staged.json

Required structure:
{
  "acb_manifest_version": "0.1",
  "commit_sha": "pending",
  "timestamp": "<ISO 8601 now>",
  "intent_groups": [
    {
      "id": "<slug>",
      "title": "<what this change does>",
      "classification": "explicit | inferred | speculative",
      "ambiguity_tags": [],
      "task_grounding": "<why, traced to the task>",
      "file_refs": [
        { "path": "<file>", "ranges": ["<N-M>"], "view_hint": "changed_region" }
      ]
    }
  ]
}

Optional fields: annotations, negative_space, open_questions

After writing the manifest, retry the commit.
To bypass (human/manual commits): git commit --no-verify

EOF
  exit 1
fi

# Validate basic structure of the manifest
if ! python3 -c "
import json, sys
try:
    doc = json.load(open('$STAGED_MANIFEST'))
    assert 'acb_manifest_version' in doc, 'missing acb_manifest_version'
    assert 'intent_groups' in doc, 'missing intent_groups'
    assert len(doc['intent_groups']) > 0, 'intent_groups is empty'
    for g in doc['intent_groups']:
        assert 'id' in g, 'intent group missing id'
        assert 'title' in g, 'intent group missing title'
        assert 'classification' in g, 'intent group missing classification'
        assert 'file_refs' in g and len(g['file_refs']) > 0, f'intent group {g[\"id\"]} missing file_refs'
except Exception as e:
    print(f'ACB manifest validation failed: {e}', file=sys.stderr)
    sys.exit(1)
" 2>&1; then
  echo "" >&2
  echo "Fix the manifest at $STAGED_MANIFEST and retry the commit." >&2
  exit 1
fi

exit 0
