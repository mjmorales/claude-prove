#!/usr/bin/env bash
#
# ACB post-commit hook: finalizes the intent manifest after a successful commit.
#
# After the commit succeeds, this hook:
# 1. Reads .acb/intents/staged.json
# 2. Updates the commit_sha field with the actual SHA
# 3. Renames it to .acb/intents/<short-sha>.json
# 4. Amends the commit to include the finalized manifest
#
# This runs automatically after every commit where a staged manifest exists.

set -euo pipefail

MANIFEST_DIR=".acb/intents"
STAGED_MANIFEST="$MANIFEST_DIR/staged.json"

# Skip if no staged manifest
if [ ! -f "$STAGED_MANIFEST" ]; then
  exit 0
fi

# Skip if already amending (prevent recursion)
if [ "${ACB_AMENDING:-}" = "1" ]; then
  exit 0
fi

# Get the commit SHA
FULL_SHA=$(git rev-parse HEAD)
SHORT_SHA=$(git rev-parse --short HEAD)
FINAL_MANIFEST="$MANIFEST_DIR/$SHORT_SHA.json"

# Update commit_sha in the manifest and rename
python3 -c "
import json
with open('$STAGED_MANIFEST') as f:
    doc = json.load(f)
doc['commit_sha'] = '$FULL_SHA'
with open('$FINAL_MANIFEST', 'w') as f:
    json.dump(doc, f, indent=2)
    f.write('\n')
" 2>/dev/null

# Remove the staged file
rm -f "$STAGED_MANIFEST"

# Amend the commit to include the finalized manifest
export ACB_AMENDING=1
git add "$FINAL_MANIFEST"
git commit --amend --no-edit --no-verify >/dev/null 2>&1

exit 0
