{
  "name": "run_state",
  "version": "1.0.0",
  "description": "JSON-first run state: prd/plan/state/report artifacts under .prove/runs with schema validation and blessed mutators",
  "requires": ["python3"],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $PLUGIN_DIR/tools/run_state/hook_guard.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $PLUGIN_DIR/tools/run_state/hook_validate.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "resume|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $PLUGIN_DIR/tools/run_state/hook_session_start.py",
            "timeout": 3000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $PLUGIN_DIR/tools/run_state/hook_stop.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "general-purpose",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $PLUGIN_DIR/tools/run_state/hook_subagent_stop.py",
            "timeout": 5000
          }
        ]
      }
    ]
  },
  "provides": {
    "commands": []
  }
}
