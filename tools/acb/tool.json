{
  "name": "acb",
  "version": "0.2.0",
  "description": "Intent-based code review: manifest assembly, web review UI, CC hook",
  "requires": ["python3", "git"],
  "directive": "Feature-branch commits must carry an ACB v0.2 intent manifest; the PostToolUse hook on `git commit` supplies the exact save command. Assemble via `/prove:review`.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "python3 $PLUGIN_DIR/tools/acb/hook.py --workspace-root $CLAUDE_PROJECT_DIR",
            "timeout": 10000
          }
        ]
      }
    ]
  },
  "directories": [".prove"],
  "config_schema": {
    "base_branch": {
      "type": "str",
      "default": "main",
      "description": "Base branch for diffs"
    }
  },
  "provides": {
    "commands": ["review", "review/fix", "review/discuss", "review/resolve"],
    "skills": ["review"]
  }}
