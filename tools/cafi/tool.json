{
  "name": "cafi",
  "version": "1.0.0",
  "description": "Content-addressable file index with routing-hint descriptions",
  "requires": ["python3"],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/tools/cafi/cafi_gate.py",
            "timeout": 10000
          }
        ]
      }
    ]
  },
  "config_schema": {
    "excludes": {
      "type": "list",
      "default": [],
      "description": "Glob patterns to exclude from indexing"
    },
    "max_file_size": {
      "type": "int",
      "default": 102400,
      "description": "Max file size in bytes for indexing"
    },
    "concurrency": {
      "type": "int",
      "default": 3,
      "description": "Number of concurrent indexing workers"
    }
  },
  "provides": {
    "commands": ["index"],
    "skills": ["index"]
  }
}
