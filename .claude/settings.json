{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "python3 $PLUGIN_DIR/tools/acb/hook.py --workspace-root $CLAUDE_PROJECT_DIR",
            "timeout": 10000
          }
        ],
        "_tool": "acb"
      }
    ]
  }
}
