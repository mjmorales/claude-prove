{
  "$schema": "../schemas/prove.schema.json",
  "schema_version": "12",
  "artifacts": {
    "html_open": "cursor {file}"
  },
  "scopes": {
    "agents": "agents/",
    "cache": "cache/",
    "commands": "commands/",
    "packages": "packages/",
    "references": "references/",
    "scrum": "packages/cli/src/topics/scrum/",
    "skills": "skills/",
    "scripts": "scripts/",
    "schemas": "schemas/"
  },
  "validators": [
    {
      "name": "comment-audit",
      "skill": "claude-skills:comment-audit",
      "phase": "llm"
    }
  ],
  "claude_md": {
    "references": [
      {
        "path": "references/llm-coding-standards.md",
        "label": "LLM-Optimized Coding Standards"
      },
      {
        "path": "references/interaction-patterns.md",
        "label": "Interaction Patterns"
      },
      {
        "path": "references/validation-config.md",
        "label": "Validation Configuration"
      },
      {
        "path": "references/creator-conventions.md",
        "label": "Creator Conventions"
      },
      {
        "path": "references/prompt-engineering-guide.md",
        "label": "Prompt Engineering Guide"
      }
    ]
  },
  "tools": {
    "pcd": {
      "enabled": true
    },
    "acb": {
      "enabled": false,
      "scope": "user",
      "config": {
        "base_branch": "main",
        "review_ui_port": 5174
      }
    },
    "cafi": {
      "enabled": true,
      "scope": "user",
      "config": {
        "excludes": [],
        "max_file_size": 102400,
        "concurrency": 3
      }
    },
    "run_state": {
      "enabled": true,
      "scope": "user"
    },
    "scrum": {
      "enabled": true,
      "scope": "user",
      "config": {}
    }
  },
  "dev_mode": true,
  "brief": {
    "single_pass_token_threshold": 8000,
    "max_synthesis_retries": 2,
    "prose_judge_on": true
  },
  "memory": {
    "stale_threshold_days": 90
  },
  "decomposition": {
    "auto_accept_through": "none"
  }
}
