{
  "schema_version": "3",
  "scopes": {
    "skills": "skills/",
    "commands": "commands/",
    "agents": "agents/",
    "scripts": "scripts/",
    "tools": "tools/",
    "plugin": ".",
    "cafi": "tools/cafi/",
    "specs": "specs/",
    "acb": "tools/acb/"
  },
  "validators": [
    {
      "name": "python-lint",
      "command": "docker run --rm -v \"$PWD\":/project prove-validators ruff check .",
      "phase": "lint"
    },
    {
      "name": "python-typecheck",
      "command": "docker run --rm -v \"$PWD\":/project prove-validators mypy --ignore-missing-imports tools/",
      "phase": "lint"
    },
    {
      "name": "python-tests",
      "command": "docker run --rm -v \"$PWD\":/project prove-validators python -m pytest tools/cafi/ tools/pcd/ tools/acb/ tools/schema/ -v",
      "phase": "test"
    }
  ],
  "reporters": [
    {
      "name": "discord-notify",
      "command": "./.prove/notify-discord.sh",
      "events": [
        "step-halted",
        "wave-complete",
        "execution-complete"
      ]
    }
  ],
  "tools": {
    "cafi": {
      "enabled": true,
      "config": {
        "excludes": [],
        "max_file_size": 102400,
        "concurrency": 3
      }
    },
    "acb": {
      "enabled": true
    },
    "pcd": {
      "enabled": true
    },
    "schema": {
      "enabled": true
    }
  }
}
