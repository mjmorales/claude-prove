{
  "validators": [
    {
      "name": "python-lint",
      "command": "docker run --rm -v \"$PWD\":/project prove-validators ruff check .",
      "phase": "lint"
    },
    {
      "name": "python-typecheck",
      "command": "docker run --rm -v \"$PWD\":/project prove-validators mypy --ignore-missing-imports tools/",
      "phase": "lint"
    },
    {
      "name": "python-tests",
      "command": "docker run --rm -v \"$PWD\":/project prove-validators python -m pytest tools/cafi/ -v",
      "phase": "test"
    }
  ],
  "reporters": [
    {
      "name": "discord-notify",
      "command": "./.prove/notify-discord.sh",
      "events": ["step-halted", "wave-complete", "execution-complete"]
    }
  ],
  "index": {
    "excludes": [],
    "max_file_size": 102400,
    "concurrency": 3
  }
}
